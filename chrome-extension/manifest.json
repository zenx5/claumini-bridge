{
  "manifest_version": 3,
  "name": "Suscription to Friend",
  "version": "1.0",
  "description": "Conecta un servidor externo con el chat de la IA.",
  "permissions": ["storage"],
  "host_permissions": [
    "*://gemini.google.com/*",
    "*://chatgpt.com/*",
    "*://claude.ai/new",
    "*://claude.ai/chat/*",
    "http://*/*",
    "https://*/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "*://gemini.google.com/*",
        "*://chatgpt.com/*",
        "*://claude.ai/new",
        "*://claude.ai/chat/*"
      ],
      "js": ["content.js"]
    }
  ]
}
